generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  comercial
  operacional
  cliente
  parceiro
}

model User {
  id            String         @id @default(uuid())
  nome          String
  email         String         @unique
  senhaHash     String         @map("senha_hash")
  role          Role           @default(cliente)
  ativo         Boolean        @default(true)
  clienteId     String?        @unique @map("cliente_id")
  createdAt     DateTime       @default(now()) @map("created_at")
  refreshTokens RefreshToken[]
  interacoes    Interacao[]
  auditLogs     AuditLog[]
  cliente       Cliente?       @relation(fields: [clienteId], references: [id])
  tecnico       Tecnico?

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Cliente {
  id                String      @id @default(uuid())
  tipo              String
  nome              String
  cpf               String?     @unique
  razaoSocial       String?     @map("razao_social")
  nomeFantasia      String?     @map("nome_fantasia")
  cnpj              String?     @unique
  responsavel       String?
  email             String
  telefone          String
  whatsapp          String?
  endereco          Json        @default("{}")
  status            String      @default("ativo")
  consentimentoLgpd Boolean     @default(false) @map("consentimento_lgpd")
  dataAceite        DateTime?   @map("data_aceite")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  user              User?
  pedidos           Pedido[]
  interacoes        Interacao[]
  pagamentos        Pagamento[]
  documentos        Documento[]
  solicitacoes      SolicitacaoServico[]
  agendamentos      Agendamento[]
  garantias         Garantia[]
  produtosInstalados ProdutoInstalado[]
  ocorrenciasAusencia Int @default(0) @map("ocorrencias_ausencia")
  campanhas           CampanhaCrm[]

  @@map("clientes")
}

model Lead {
  id          String      @id @default(uuid())
  nome        String
  cpfCnpj     String?     @map("cpf_cnpj")
  telefone    String
  email       String
  origem      String
  interesse   String
  responsavel String
  etapa       String      @default("novo_lead")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  interacoes  Interacao[]

  @@map("leads")
}

model Interacao {
  id        String   @id @default(uuid())
  leadId    String?  @map("lead_id")
  clienteId String?  @map("cliente_id")
  tipo      String
  descricao String
  data      DateTime @default(now())
  usuarioId String   @map("usuario_id")
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  cliente   Cliente? @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  usuario   User     @relation(fields: [usuarioId], references: [id])

  @@map("interacoes")
}

model Pedido {
  id           String        @id @default(uuid())
  numero       String        @unique
  clienteId    String        @map("cliente_id")
  servicoId    String?       @map("servico_id")
  valor        Decimal       @db.Decimal(12, 2)
  responsavel  String
  status       String        @default("recebido")
  descricao    String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  cliente      Cliente       @relation(fields: [clienteId], references: [id])
  servico      Servico?      @relation(fields: [servicoId], references: [id])
  ordemServico OrdemServico?
  pagamentos   Pagamento[]
  solicitacao  SolicitacaoServico?
  agendamentos Agendamento[]

  @@map("pedidos")
}

model OrdemServico {
  id                String   @id @default(uuid())
  pedidoId          String   @unique @map("pedido_id")
  etapa             String   @default("solicitacao")
  observacoes       String?
  parceiro          String?
  checklist         Json     @default("{}")
  checklistCompleto Boolean  @default(false) @map("checklist_completo")
  garantiaId        String?     @map("garantia_id")
  tecnicoId         String?     @map("tecnico_id")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  pedido            Pedido      @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  tecnico           Tecnico?    @relation(fields: [tecnicoId], references: [id])
  avaliacao         Avaliacao?

  @@map("ordens_servico")
}

model Pagamento {
  id          String    @id @default(uuid())
  clienteId   String    @map("cliente_id")
  pedidoId    String?   @map("pedido_id")
  asaasId     String?   @unique @map("asaas_id")
  valor       Decimal   @db.Decimal(12, 2)
  metodo      String
  status      String    @default("PENDING")
  dueDate     DateTime  @map("due_date")
  paymentDate DateTime? @map("payment_date")
  invoiceUrl  String?   @map("invoice_url")
  pixCode     String?   @map("pix_code")
  createdAt   DateTime  @default(now()) @map("created_at")
  cliente     Cliente   @relation(fields: [clienteId], references: [id])
  pedido      Pedido?   @relation(fields: [pedidoId], references: [id])

  @@map("pagamentos")
}

model Servico {
  id          String   @id @default(uuid())
  nome        String
  categoria   String
  descricao   String
  preco       Decimal? @db.Decimal(12, 2)
  parceiro    String?
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  pedidos     Pedido[]

  @@map("servicos")
}

model Beneficio {
  id        String   @id @default(uuid())
  parceiro  String
  categoria String
  descricao String
  cupom     String?
  cashback  Decimal? @db.Decimal(12, 2)
  desconto  Decimal? @db.Decimal(5, 2)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("beneficios")
}

model Parceiro {
  id        String   @id @default(uuid())
  nome      String
  cnpj      String?  @unique
  email     String
  telefone  String
  categoria String
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("parceiros")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  acao      String
  recurso   String
  recursoId String?  @map("recurso_id")
  detalhes  Json?
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Notificacao {
  id        String   @id @default(uuid())
  tipo      String
  canal     String
  destino   String
  assunto   String?
  mensagem  String
  status    String   @default("enviada")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notificacoes")
}

model Documento {
  id         String   @id @default(uuid())
  clienteId  String   @map("cliente_id")
  nome       String
  filename   String
  mimetype   String
  tamanho    Int
  url        String
  createdAt  DateTime @default(now()) @map("created_at")
  cliente    Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@map("documentos")
}

model Movimentacao {
  id          String   @id @default(uuid())
  tipo        String
  categoria   String
  descricao   String
  valor       Decimal? @db.Decimal(12, 2)
  quantidade  Int      @default(1)
  responsavel String
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("movimentacoes")
}

model CatalogoServico {
  id           String              @id @default(uuid())
  slug         String              @unique
  nome         String
  tipo         String              @default("C")
  pontos       Int                 @default(1)
  categoria    String              @default("eletricista")
  descricao    String?             @db.Text
  precoTexto   String?             @map("preco_texto")
  precoMinimo  Decimal?            @map("preco_minimo") @db.Decimal(12, 2)
  tipoPreco    String              @default("fixo") @map("tipo_preco")
  garantiaDias Int                 @default(90) @map("garantia_dias")
  imagemUrl    String?             @map("imagem_url")
  ordem        Int                 @default(0)
  upsells      Json                @default("[]")
  ativo        Boolean             @default(true)
  createdAt    DateTime            @default(now()) @map("created_at")
  precosFixos  PrecoFixo[]
  solicitacoes SolicitacaoServico[]

  @@map("catalogo_servicos")
}

model PrecoFixo {
  id        String          @id @default(uuid())
  servicoId String          @map("servico_id")
  chave     String
  label     String
  preco     Decimal         @db.Decimal(12, 2)
  servico   CatalogoServico @relation(fields: [servicoId], references: [id], onDelete: Cascade)

  @@unique([servicoId, chave])
  @@map("precos_fixos")
}

model ConfigSistema {
  id               String  @id @default("default")
  impostos         Decimal @default(0.14) @db.Decimal(5, 4)
  taxaCartao       Decimal @default(0.04) @map("taxa_cartao") @db.Decimal(5, 4)
  lucro            Decimal @default(0.25) @db.Decimal(5, 4)
  overhead         Decimal @default(0.15) @db.Decimal(5, 4)
  expressValor     Decimal @default(29) @map("express_valor") @db.Decimal(12, 2)
  taxaCancelamento Decimal @default(49) @map("taxa_cancelamento") @db.Decimal(12, 2)
  taxaAusencia     Decimal @default(49) @map("taxa_ausencia") @db.Decimal(12, 2)

  @@map("config_sistema")
}

model ProdutoEstoque {
  id          String @id @default(uuid())
  sku         String @unique
  nome        String
  quantidade  Int    @default(0)
  reservado   Int    @default(0)
  minimo      Int    @default(5)
  critico     Int    @default(2)
  servicoSlug String? @map("servico_slug")

  @@map("produto_estoque")
}

model Tecnico {
  id               String          @id @default(uuid())
  nome             String
  userId           String?         @unique @map("user_id")
  capacidadeDiaria Int             @default(6) @map("capacidade_diaria")
  ativo            Boolean         @default(true)
  agendamentos     Agendamento[]
  ordensServico    OrdemServico[]
  user             User?           @relation(fields: [userId], references: [id])

  @@map("tecnicos")
}

model Agendamento {
  id            String             @id @default(uuid())
  clienteId     String             @map("cliente_id")
  pedidoId      String?            @map("pedido_id")
  solicitacaoId String?            @unique @map("solicitacao_id")
  tecnicoId     String?            @map("tecnico_id")
  data          DateTime
  horarioInicio String             @map("horario_inicio")
  horarioFim    String             @map("horario_fim")
  pontosUsados  Int                @map("pontos_usados")
  express       Boolean            @default(false)
  status        String             @default("confirmado")
  canceladoEm   DateTime?          @map("cancelado_em")
  taxaCobrada   Decimal?           @map("taxa_cobrada") @db.Decimal(12, 2)
  lembrete1dEnviado Boolean          @default(false) @map("lembrete_1d_enviado")
  lembrete2hEnviado Boolean          @default(false) @map("lembrete_2h_enviado")
  createdAt     DateTime           @default(now()) @map("created_at")
  cliente       Cliente            @relation(fields: [clienteId], references: [id])
  pedido        Pedido?            @relation(fields: [pedidoId], references: [id])
  solicitacao   SolicitacaoServico? @relation(fields: [solicitacaoId], references: [id])
  tecnico       Tecnico?           @relation(fields: [tecnicoId], references: [id])

  @@map("agendamentos")
}

model SolicitacaoServico {
  id                  String          @id @default(uuid())
  clienteId           String          @map("cliente_id")
  servicoId           String          @map("servico_id")
  tipo                String
  opcoes              Json            @default("{}")
  fotos               Json            @default("[]")
  analiseIa           Json?           @map("analise_ia")
  status              String          @default("rascunho")
  precoBase           Decimal?        @map("preco_base") @db.Decimal(12, 2)
  precoFinal          Decimal?        @map("preco_final") @db.Decimal(12, 2)
  upsellsSelecionados Json            @default("[]") @map("upsells_selecionados")
  nivelComplexidade   Int?            @map("nivel_complexidade")
  confiancaIa         Decimal?        @map("confianca_ia") @db.Decimal(5, 2)
  express             Boolean         @default(false)
  pedidoId            String?         @unique @map("pedido_id")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")
  cliente             Cliente         @relation(fields: [clienteId], references: [id])
  servico             CatalogoServico @relation(fields: [servicoId], references: [id])
  pedido              Pedido?         @relation(fields: [pedidoId], references: [id])
  agendamento         Agendamento?

  @@map("solicitacoes_servico")
}

model Garantia {
  id         String   @id @default(uuid())
  numero     String   @unique
  clienteId  String   @map("cliente_id")
  pedidoId   String   @map("pedido_id")
  servico    String
  produto    String
  dataInicio DateTime @map("data_inicio")
  dataFim    DateTime @map("data_fim")
  cliente    Cliente  @relation(fields: [clienteId], references: [id])

  @@map("garantias")
}

model ProdutoInstalado {
  id         String   @id @default(uuid())
  clienteId  String   @map("cliente_id")
  nome       String
  servico    String
  data       DateTime @default(now())
  garantiaId String?  @map("garantia_id")
  cliente    Cliente  @relation(fields: [clienteId], references: [id])

  @@map("produtos_instalados")
}

model Avaliacao {
  id             String       @id @default(uuid())
  ordemServicoId String       @unique @map("ordem_servico_id")
  clienteId      String       @map("cliente_id")
  nota           Int
  comentario     String?
  createdAt      DateTime     @default(now()) @map("created_at")
  ordemServico   OrdemServico @relation(fields: [ordemServicoId], references: [id], onDelete: Cascade)

  @@map("avaliacoes")
}

model CampanhaCrm {
  id           String   @id @default(uuid())
  clienteId    String   @map("cliente_id")
  tipo         String
  titulo       String
  mensagem     String
  status       String   @default("pendente")
  agendadaPara DateTime @map("agendada_para")
  enviadaEm    DateTime? @map("enviada_em")
  createdAt    DateTime @default(now()) @map("created_at")
  cliente      Cliente  @relation(fields: [clienteId], references: [id])

  @@map("campanhas_crm")
}
