# Cole TUDO abaixo em: EasyPanel → Projeto → Environment
# Variáveis mágicas EasyPanel: $(PRIMARY_DOMAIN) = domínio do serviço web
#
# Valores reais: copie de deploy/easypanel.env.local (só na sua máquina)
# ou de backend/.env + ajuste FRONTEND_URL e JWT para produção

# ── Supabase ──
DATABASE_URL=postgresql://postgres.[REF]:[SENHA]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[REF]:[SENHA]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres
SUPABASE_URL=https://[REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=[SUA_SERVICE_ROLE_KEY]
SUPABASE_STORAGE_BUCKET=documentos

# ── JWT (produção — gere strings longas e únicas) ──
JWT_SECRET=[JWT_SECRET_PRODUCAO_64_CHARS]
JWT_REFRESH_SECRET=[JWT_REFRESH_SECRET_PRODUCAO_64_CHARS]
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── URLs (EasyPanel preenche o domínio automaticamente) ──
FRONTEND_URL=https://$(PRIMARY_DOMAIN)
API_PUBLIC_URL=https://$(PRIMARY_DOMAIN)

# ── Asaas (produção) ──
ASAAS_API_KEY=[SUA_API_KEY_ASAAS]
ASAAS_API_URL=https://api.asaas.com/v3
ASAAS_CNPJ=[CNPJ_EMPRESA]

# ── Opcional ──
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@absresolve.com.br
WHATSAPP_TOKEN=
WHATSAPP_API_URL=

# ── Primeiro deploy: true (cria usuários demo). Depois mude para false ──
RUN_SEED=true
